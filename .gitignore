# ============================================================
# Swift Package Manager
# ============================================================

.build/
.swiftpm/
*.o
*.d

# Generated Xcode project (if you ever run `swift package generate-xcodeproj`)
*.xcodeproj

# Swift Package resolved dependencies — commit this if you have dependencies,
# leave ignored if the package has no external dependencies (which is likely here)
# Package.resolved

# ============================================================
# Xcode
# ============================================================

# User-specific Xcode settings
xcuserdata/
*.xcuserstate
*.xcscmblueprint

# Xcode derived data (if you open the package in Xcode)
DerivedData/

# Xcode Previews
*.xcpreviewdata

# Playground generated files
timeline.xctimeline
playground.xcworkspace

